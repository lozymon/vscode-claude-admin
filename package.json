{
  "name": "vscode-claude-admin",
  "displayName": "Claude Code Admin",
  "description": "GUI admin panel for Claude Code configuration",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeAdmin.open",
        "title": "Claude Code Admin: Open",
        "icon": "media/claude-icon.svg"
      },
      {
        "command": "claudeAdmin.refresh",
        "title": "Claude Code Admin: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "claudeAdmin.open",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudeAdmin.open",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3"
  }
}
